# ==============================================================================
# Senic Billing Next — Portainer Stack Environment Variables
# ==============================================================================

# Database Credentials
DB_USER=postgres
DB_PASSWORD=SecurePassword123!
DB_NAME=senic_billing
DB_PORT=5432

# Backend Configuration
BACKEND_PORT=8080

# Frontend Configuration
FRONTEND_PORT=8810

# Admin Frontend Configuration
ADMIN_FRONTEND_PORT=8811

# JWT Configuration
JWT_SECRET=SenicBillingNextSuperSecretKey2026!@#$%^&*()_+1234567890
JWT_ISSUER=SenicBillingNext
JWT_AUDIENCE=SenicBillingNextClient
JWT_EXPIRY=480

# Web Push Notifications (VAPID)
VAPID_SUBJECT=mailto:admin@senic.co.th
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here

# Gemini AI Integration
GEMINI_API_KEY=your_gemini_api_key_here

# Omise Payment Integration
OMISE_PUBLIC_KEY=pkey_test_your_omise_public_key_here
OMISE_SECRET_KEY=skey_test_your_omise_secret_key_here

# SMTP Configuration (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-16-character-app-password
SMTP_FROM_NAME=Senic Billing
SMTP_FROM_EMAIL=your-email@gmail.com

# GitHub Repository Name (for GHCR image pulling)
# FORMAT: username/repo-name (Must be lowercase)
GITHUB_REPOSITORY=picthaisky/senic-billing-next
